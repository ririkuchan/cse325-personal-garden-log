@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Home</PageTitle>

<div class="p-5 mb-4 bg-light rounded-3">
    <div class="container-fluid py-5">
        <h1 class="display-5 fw-bold">Welcome to Garden Log</h1>
        <p class="col-md-8 fs-4">
            Manage your personal garden records, track your planting history, and watch your garden grow!
        </p>

        <AuthorizeView>
            <Authorized>
                <p>Hello, <strong>@context.User.Identity?.Name</strong>!</p>
                <a href="garden" class="btn btn-primary btn-lg">Go to My Garden Log</a>
            </Authorized>
            <NotAuthorized>
                <div class="mt-4">
                    <a href="Account/Login" class="btn btn-primary btn-lg">Login to start</a>
                    <a href="Account/Register" class="btn btn-outline-secondary btn-lg">Register</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>